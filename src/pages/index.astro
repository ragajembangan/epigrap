  </main>

</body>
</html>

<style>
  /* Base Setup */
  :root {
    --color-obsidian: #0D0E10;
    --color-brass: #C5A059;
    --color-parchment: #F4EEDF;
    --font-heading: 'Cinzel', 'Playfair Display', serif;
    --font-body: 'Inter', 'Outfit', sans-serif;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  html, body {
    width: 100%;
    height: 100%;
    overflow: hidden; /* Mencegah scrolling */
    background-color: var(--color-obsidian);
    font-family: var(--font-body);
  }

  .teaser-wrapper {
    position: relative;
    width: 100vw;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Latar Gambar Gerhana Emas */
  .bg-eclipse {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    z-index: 1;
    opacity: 0.95;
    animation: pulseGlow 8s ease-in-out infinite alternate;
  }

  /* Overlay Hitam Halus agar teks selalu aman */
  .bg-overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    background: radial-gradient(circle at center, rgba(13,14,16,0.3) 0%, rgba(13,14,16,0.7) 60%, rgba(13,14,16,0.9) 100%);
  }

  /* Kotak Konten Utama di Tengah */
  .content-core {
    position: relative;
    z-index: 10;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    /* Memberi ruang ekstra untuk pas di tengah area hitam gerhana */
    padding: 2rem;
  }

  .brand-title {
    font-family: var(--font-heading);
    font-size: 4rem;
    font-weight: 700;
    letter-spacing: 0.25em;
    color: var(--color-brass);
    text-shadow: 0 4px 30px rgba(197,160,89, 0.4);
    margin-bottom: 0.5rem;
    margin-right: -0.25em; /* Compensate for letter spacing */
    animation: fadeUp 1s ease-out forwards;
  }

  .brand-subtitle {
    font-size: 0.85rem;
    letter-spacing: 0.4em;
    color: var(--color-parchment);
    text-transform: uppercase;
    font-weight: 500;
    margin-right: -0.4em; /* Compensate */
    opacity: 0;
    animation: fadeUp 1s ease-out 0.3s forwards;
  }

  /* Form Tunggu / Waitlist */
  .waitlist-container {
    margin-top: 3rem;
    opacity: 0;
    animation: fadeUp 1s ease-out 0.6s forwards;
  }

  .waitlist-text {
    font-size: 0.85rem;
    color: var(--color-parchment);
    opacity: 0.6;
    margin-bottom: 1rem;
    font-style: italic;
  }

  .waitlist-form {
    display: flex;
    align-items: stretch;
    justify-content: center;
    max-width: 400px;
    margin: 0 auto;
    position: relative;
    border-radius: 100px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(197, 160, 89, 0.3);
    overflow: hidden;
    backdrop-filter: blur(5px);
    transition: border-color 0.3s ease;
  }
  .waitlist-form:focus-within {
    border-color: var(--color-brass);
    box-shadow: 0 0 20px rgba(197,160,89,0.2);
  }

  .waitlist-input {
    flex: 1;
    background: transparent;
    border: none;
    color: var(--color-parchment);
    padding: 1rem 1.5rem;
    font-size: 0.9rem;
    outline: none;
    width: 100%;
  }
  .waitlist-input::placeholder { color: rgba(244, 238, 223, 0.4); }

  .waitlist-button {
    background: var(--color-brass);
    color: var(--color-obsidian);
    border: none;
    padding: 0 1.5rem;
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.3s ease;
  }
  .waitlist-button:hover {
    background: var(--color-parchment);
  }

  /* Footer Sosmed (Meniru Portal) */
  .social-footer {
    position: absolute;
    bottom: 2.5rem;
    width: 100%;
    z-index: 10;
    display: flex;
    justify-content: center;
    opacity: 0;
    animation: fadeUp 1s ease-out 0.9s forwards;
  }
  .sosmed-icons {
    display: flex;
    gap: 1.25rem;
  }
  .sosmed-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.1);
    background: rgba(13,14,16, 0.5);
    backdrop-filter: blur(5px);
    color: var(--color-parchment);
    opacity: 0.6;
    transition: all 0.3s ease;
    text-decoration: none;
  }
  .sosmed-link:hover {
    opacity: 1;
    color: var(--color-brass);
    border-color: var(--color-brass);
    transform: translateY(-3px);
    box-shadow: 0 6px 20px rgba(197,160,89,0.2);
  }

  /* --- Keyframe Animations --- */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes pulseGlow {
    from { transform: scale(1); filter: contrast(1); }
    to { transform: scale(1.02); filter: contrast(1.1) brightness(1.05); }
  }

  @keyframes pulseGlowMobile {
    from { transform: scale(1.2); filter: contrast(1); }
    to { transform: scale(1.22); filter: contrast(1.1) brightness(1.05); }
  }

  /* Responsiveness */
  @media (max-width: 768px) {
    html, body {
      background-color: #000;
      height: 100%;
    }
    .teaser-wrapper {
      position: relative;
      min-height: 100dvh;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      overflow: hidden;
    }
    .bg-eclipse {
      position: absolute;
      top: 15vh;
      height: 70vh;
      width: 100%;
      object-fit: cover;
      object-position: center center;
      /* Matikan animasi desktop dan gunakan animasi mobile */
      animation: pulseGlowMobile 8s ease-in-out infinite alternate;
      -webkit-mask-image: linear-gradient(to bottom, transparent 0%, black 15%, black 85%, transparent 100%);
      mask-image: linear-gradient(to bottom, transparent 0%, black 15%, black 85%, transparent 100%);
    }
    .content-core {
      position: relative;
      z-index: 10;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      width: 100%;
      padding: 0 1rem;
      margin-top: 0; /* Pastikan center */
    }
    .brand-title { 
      font-size: 2.2rem; 
      letter-spacing: 0.25em;
      margin: 0;
    }
    .brand-subtitle { 
      font-size: 0.65rem; 
      letter-spacing: 0.3em; 
      margin-bottom: 1.5rem; /* Jarak rapat ke form */
    }
    .waitlist-container {
      width: 100%;
      display: flex;
      flex-direction: column;
      align-items: center;
      margin-top: 0;
    }
    .waitlist-form { 
      width: 60%; /* Menyempitkan agar muat di dalam lingkaran */
      max-width: 220px;
      flex-direction: column; 
      border-radius: 12px; 
      background: transparent; 
      border: none; 
      gap: 0.75rem; 
    }
    .waitlist-input { 
      border-radius: 12px; 
      border: 1px solid rgba(197, 160, 89, 0.4); 
      background: rgba(0,0,0,0.7); 
      text-align: center;
      width: 100%;
      padding: 0.8rem 1rem;
      font-size: 0.8rem;
    }
    .waitlist-button { 
      border-radius: 12px; 
      padding: 0.8rem; 
      width: 100%;
      font-size: 0.75rem;
    }
    .social-footer {
      bottom: 2rem;
      position: absolute;
      z-index: 20;
    }
  }
</style>
