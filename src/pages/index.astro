---
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Epigrap — Preserving Heritage</title>
  <meta name="description" content="A bridge between physical monuments and digital eternity. Coming soon." />
  
  <!-- Preload Font / Image -->
  <link rel="preload" as="image" href="/bg-eclipse.webp" />
</head>
<body class="teaser-body">
  
  <main class="teaser-wrapper">
    <!-- Background Image -->
    <img src="/bg-eclipse.webp" alt="Golden Solar Eclipse Background" class="bg-eclipse" />
    
    <!-- Subtle Overlay in case the center isn't 100% black -->
    <div class="bg-overlay"></div>

    <!-- Center Content inside the Ring -->
    <div class="content-core">
      <h1 class="brand-title">EPIGRAP</h1>
      <p class="brand-subtitle">PRESERVING HERITAGE</p>
      
      <!-- Waitlist / Newsletter Section -->
      <div class="waitlist-container">
        <p class="waitlist-text">Coming soon...</p>
        <form class="waitlist-form" onsubmit="event.preventDefault(); alert('Terima kasih! Alamat email Anda telah tercatat.');">
          <input type="email" placeholder="Enter your email" required class="waitlist-input" />
          <button type="submit" class="waitlist-button">Notify Me</button>
        </form>
      </div>

    </div>

    <!-- Social Links (Absolut Bottom) -->
    <div class="social-footer">
      <div class="sosmed-icons">
        <a href="https://instagram.com/epigrap" target="_blank" rel="noopener noreferrer" class="sosmed-link" aria-label="Instagram">
