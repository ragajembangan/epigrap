---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const allCategories = [...new Set(posts.map(p => p.data.category).filter(Boolean))].sort();
---

<BaseLayout 
  title="Insights & Inovasi — Epigrap Blog" 
  description="Artikel, insight, dan berita terbaru dari Epigrap mengenai pelestarian sejarah digital dan phygital."
>
  <section class="blog-header-section">
    <div class="container">
      <h1 class="blog-title">Insights & <span class="text-brass">Inovasi</span></h1>
      <p class="blog-subtitle">Menelusuri jejak peradaban, merawat masa depan. Temukan gagasan kami tentang teknologi pengarsipan dan sejarah.</p>
    </div>
  </section>

  <section class="blog-grid-section">
    <div class="container">
      <!-- Search & Filter Bar -->
      <div class="blog-toolbar">
        <div class="filter-tags">
          <button class="filter-tag active" data-category="all">Semua</button>
          {allCategories.map(cat => (
            <button class="filter-tag" data-category={cat}>{cat}</button>
          ))}
        </div>
        
        <div class="search-wrapper">
          <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          <input 
            type="text" 
            id="blog-search" 
            class="blog-search-input"
            placeholder="Cari artikel..." 
            autocomplete="off"
          />
        </div>
      </div>

      <!-- Blog Grid -->
      <div class="blog-grid" id="blog-grid">
        {posts.map(post => (
          <BlogCard 
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            coverImage={post.data.coverImage}
            url={`/blog/${post.id}`}
            tags={post.data.tags}
            category={post.data.category}
          />
        ))}
      </div>

      <!-- No results message (hidden by default) -->
      <div class="no-results" id="no-results" style="display:none;">
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" style="color:#444;margin-bottom:1rem;"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/><path d="M8 11h6"/></svg>
        <p>Tidak ada artikel yang cocok dengan pencarian Anda.</p>
      </div>
    </div>
  </section>
</BaseLayout>

<style is:global>
  /* ===== Blog Header ===== */
  .blog-header-section {
    padding: 8rem 0 4rem;
    text-align: center;
    background-color: var(--color-obsidian);
  }

  .blog-title {
    font-size: clamp(2.5rem, 5vw, 4rem);
    margin-bottom: 1rem;
  }

  .blog-subtitle {
    font-size: 1.1rem;
    color: #a0a0a0;
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .blog-grid-section {
    padding-bottom: 8rem;
    background-color: var(--color-obsidian);
  }

  /* ===== Toolbar ===== */
  .blog-toolbar {
    margin-bottom: 2.5rem;
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    gap: 1.2rem;
    flex-wrap: wrap-reverse;
  }

  .search-wrapper {
    position: relative;
    width: 100%;
    max-width: 320px;
    flex: 1;
    min-width: 250px;
  }

  .search-icon {
    position: absolute;
    left: 1rem;
    top: 50%;
    transform: translateY(-50%);
    color: #555;
    pointer-events: none;
    z-index: 1;
  }

  .blog-search-input {
    width: 100%;
    padding: 0.85rem 1rem 0.85rem 2.8rem;
    background-color: #1a1a1a;
    border: 1px solid rgba(197, 160, 89, 0.2);
    border-radius: 10px;
    color: #f5f0e8;
    font-size: 0.95rem;
    font-family: inherit;
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
    outline: none;
    box-sizing: border-box;
    -webkit-appearance: none;
    appearance: none;
  }

  .blog-search-input::placeholder {
    color: #555;
  }

  .blog-search-input:focus {
    border-color: #c5a059;
    box-shadow: 0 0 0 3px rgba(197, 160, 89, 0.1);
  }

  .filter-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
  }

  .filter-tag {
    padding: 0.45rem 1.1rem;
    border-radius: 50px;
    border: 1px solid rgba(197, 160, 89, 0.2);
    background-color: transparent;
    color: #777;
    font-size: 0.82rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.3s ease;
    font-family: inherit;
    letter-spacing: 0.3px;
    line-height: 1;
    -webkit-appearance: none;
    appearance: none;
  }

  .filter-tag:hover {
    border-color: #c5a059;
    color: #c5a059;
    background-color: rgba(197, 160, 89, 0.06);
  }

  .filter-tag.active {
    background-color: rgba(197, 160, 89, 0.15);
    border-color: #c5a059;
    color: #c5a059;
  }

  /* ===== Grid ===== */
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 2rem;
    max-width: 1200px;
  }

  .blog-grid > * {
    max-width: 420px;
  }

  .blog-grid > .hidden {
    display: none;
  }

  /* ===== No Results ===== */
  .no-results {
    text-align: center;
    padding: 4rem 2rem;
    color: #555;
    font-size: 1.05rem;
  }

  /* ===== Mobile ===== */
  @media (max-width: 576px) {
    .blog-grid {
      grid-template-columns: 1fr;
    }

    .blog-grid > * {
      max-width: none;
    }

    .search-wrapper {
      max-width: none;
    }
  }
</style>

<script>
  function initBlogFilter() {
    const searchInput = document.getElementById('blog-search') as HTMLInputElement | null;
    const filterButtons = document.querySelectorAll('.filter-tag');
    const cards = document.querySelectorAll('.blog-card');
    const noResults = document.getElementById('no-results');

    if (!searchInput || cards.length === 0) return;

    let activeCategory = 'all';

    function filterCards() {
      const query = ((searchInput as HTMLInputElement)?.value || '').toLowerCase().trim();
      let visibleCount = 0;

      cards.forEach(card => {
        const title = card.getAttribute('data-title') || '';
        const desc = card.getAttribute('data-desc') || '';
        const category = card.getAttribute('data-category') || '';

        const matchesSearch = !query || title.includes(query) || desc.includes(query);
        const matchesCategory = activeCategory === 'all' || category === activeCategory;

        if (matchesSearch && matchesCategory) {
          card.classList.remove('hidden');
          visibleCount++;
        } else {
          card.classList.add('hidden');
        }
      });

      if (noResults) {
        noResults.style.display = visibleCount === 0 ? 'block' : 'none';
      }
    }

    searchInput.addEventListener('input', filterCards);

    filterButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        filterButtons.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        activeCategory = btn.getAttribute('data-category') || 'all';
        filterCards();
      });
    });
  }

  initBlogFilter();
  document.addEventListener('astro:page-load', initBlogFilter);
</script>
