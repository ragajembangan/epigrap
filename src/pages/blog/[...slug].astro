---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCTA from '../../components/BlogCTA.astro';


export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return blogEntries.map(entry => ({
    params: { slug: entry.id }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const formattedDate = new Intl.DateTimeFormat('id-ID', {
  day: 'numeric',
  month: 'long',
  year: 'numeric'
}).format(entry.data.pubDate);
---

<BaseLayout title={`${entry.data.title} — Epigrap Blog`} description={entry.data.description}>
  
  <article class="blog-article">
    <header class="article-header container">
      <div class="article-meta">
        <span class="meta-date">{formattedDate}</span>
        <span class="meta-separator">•</span>
        <span class="meta-author">Oleh {entry.data.author}</span>
      </div>
      <h1 class="article-title">{entry.data.title}</h1>
    </header>

    <div class="article-cover-container">
      <img 
        src={entry.data.coverImage} 
        alt={entry.data.title} 
        class="article-cover" 
      />
    </div>

    <div class="container article-body">
      <div class="markdown-content">
        <Content />
      </div>
      
      <BlogCTA />
    </div>
  </article>

</BaseLayout>

<style>
  .blog-article {
    padding-top: 8rem;
    background-color: var(--color-obsidian);
    min-height: 100vh;
  }

  .article-header {
    text-align: center;
    max-width: 900px;
    margin: 0 auto 3rem;
  }

  .article-meta {
    font-size: 0.9rem;
    color: var(--color-brass);
    margin-bottom: 1rem;
    font-weight: 500;
  }

  .meta-separator {
    margin: 0 0.5rem;
    color: #555;
  }

  .article-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    line-height: 1.2;
    margin: 0;
  }

  .article-cover-container {
    max-width: 900px;
    margin: 0 auto 4rem;
    padding: 0 1rem;
  }

  .article-cover {
    width: 100%;
    height: auto;
    aspect-ratio: 21 / 9;
    object-fit: cover;
    border-radius: 16px;
    box-shadow: 0 10px 40px rgba(0,0,0,0.5);
  }

  .article-body {
    max-width: 900px;
    margin: 0 auto;
    padding-bottom: 4rem;
    padding-left: 1rem;
    padding-right: 1rem;
  }
</style>

<style is:global>
  /* =============================================
     MARKDOWN CONTENT STYLING
     ============================================= */
  .markdown-content {
    font-family: var(--font-body);
    font-size: 1.1rem;
    line-height: 1.8;
    color: #e0e0e0;
  }

  .markdown-content h2,
  .markdown-content h3,
  .markdown-content h4 {
    font-family: var(--font-heading);
    color: var(--color-parchment);
    margin-top: 2.5em;
    margin-bottom: 1em;
    line-height: 1.3;
  }

  .markdown-content h2 {
    font-size: 2rem;
    border-bottom: 1px solid rgba(197, 160, 89, 0.2);
    padding-bottom: 0.5em;
  }

  .markdown-content h3 {
    font-size: 1.5rem;
  }

  .markdown-content p {
    margin-bottom: 1.5em;
  }

  .markdown-content a {
    color: var(--color-brass);
    text-decoration: none;
    border-bottom: 1px dashed var(--color-brass);
    transition: all 0.3s;
  }

  .markdown-content a:hover {
    color: #fff;
    border-bottom-color: #fff;
  }

  .markdown-content ul,
  .markdown-content ol {
    margin-bottom: 1.5em;
    padding-left: 1.5rem;
  }

  .markdown-content li {
    margin-bottom: 0.5em;
  }

  .markdown-content blockquote {
    border-left: 4px solid var(--color-velvet);
    padding-left: 1.5rem;
    margin: 2em 0;
    font-style: italic;
    color: #ccc;
    background: rgba(122, 16, 26, 0.05);
    padding: 1rem 1.5rem;
    border-radius: 0 8px 8px 0;
  }

  .markdown-content img {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
    margin: 2em 0;
  }

  .markdown-content strong {
    color: var(--color-parchment);
    font-weight: 700;
  }
</style>
