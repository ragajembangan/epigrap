---
import type { HomepageTrustItem } from '../../lib/sanity';

interface Props {
  title?: string;
  desc?: string;
  items?: HomepageTrustItem[];
  blockchainTitle?: string;
  blockchainDesc?: string;
}

const defaultItems: HomepageTrustItem[] = [
  {
    _key: 'default-1',
    itemTitle: 'Arsitektur Terlindungi',
    itemDesc: 'Akses berlapis menggunakan protokol enkripsi terkini. Kami memastikan informasi privat Anda tidak dapat dirambah oleh publik.',
  },
  {
    _key: 'default-2',
    itemTitle: 'Log Forensik Akses',
    itemDesc: 'Seluruh riwayat akses dicatat dengan rapi. Anda akan memiliki laporan komprehensif terkait siapa, kapan, dan di mana arsip Anda dilihat.',
  },
  {
    _key: 'default-3',
    itemTitle: 'Kendali Penuh Klien',
    itemDesc: 'Anda memutuskan siapa yang memegang kunci untuk membuka portal arsip. Epigrap tidak pernah mengklaim kepemilikan data historis Anda.',
  },
];

// SVG icons for trust items (keep hardcoded)
const trustIcons = [
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>`,
];

const {
  title = 'Kepercayaan Tanpa Kompromi',
  desc = 'Keamanan digital tingkat institusi untuk menjaga eksklusivitas arsip publik dan privat Anda.',
  items = defaultItems,
  blockchainTitle = 'Penyimpanan Permanen Lintas Abad',
  blockchainDesc = 'Sebagai add-on opsional, konten yang telah melalui tinjauan tim Epigrap dapat diabadikan secara permanen ke jaringan blockchain Arweave & Polygon — kebal terhadap sensor, penghapusan, maupun kegagalan server. Sebuah warisan yang tidak hanya tersimpan, tetapi terverifikasi abadi.',
} = Astro.props;
---
<section class="trust-section">
  <div class="container trust-container">
    <div class="trust-header">
      <h2 class="section-title">{title}</h2>
      <p class="section-desc">{desc}</p>
    </div>

    <div class="trust-grid">
      {items.map((item, i) => (
        <div class="trust-item">
          <div class="icon-shield">
            <Fragment set:html={trustIcons[i] || trustIcons[0]} />
          </div>
          <h4>{item.itemTitle}</h4>
          <p>{item.itemDesc}</p>
        </div>
      ))}
    </div>

    <div class="trust-banner-blockchain">
      <div class="blockchain-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path>
          <polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline>
          <line x1="12" y1="22.08" x2="12" y2="12"></line>
        </svg>
      </div>
      <div class="blockchain-content">
        <h3>{blockchainTitle}</h3>
        <p>{blockchainDesc}</p>
      </div>
    </div>
  </div>
</section>

<style>
  .trust-section {
    padding: 8rem 0;
    background-color: var(--color-granite);
    border-top: 1px solid rgba(255,255,255,0.05);
  }

  .trust-header {
    text-align: center;
    margin-bottom: 5rem;
  }

  .section-title {
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: 1rem;
    color: var(--color-brass);
  }

  .section-desc {
    color: #888;
    max-width: 600px;
    margin: 0 auto;
    font-size: 1.1rem;
  }

  .trust-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3rem;
  }

  .trust-item {
    text-align: center;
    padding: 2rem;
    transition: transform 0.3s;
  }

  .trust-item:hover {
    transform: translateY(-5px);
  }

  .icon-shield {
    width: 60px;
    height: 60px;
    margin: 0 auto 1.5rem;
    color: var(--color-brass);
  }
  
  .icon-shield svg {
    width: 100%;
    height: 100%;
  }

  .trust-item h4 {
    font-size: 1.3rem;
    margin-bottom: 1rem;
    color: var(--color-parchment);
    font-family: var(--font-heading);
  }

  .trust-item p {
    color: #999;
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .trust-banner-blockchain {
    margin-top: 5rem;
    background: linear-gradient(90deg, rgba(122, 16, 26, 0.1) 0%, rgba(197, 160, 89, 0.05) 100%);
    border: 1px solid rgba(197, 160, 89, 0.3);
    border-radius: 8px;
    padding: 3rem;
    display: flex;
    align-items: center;
    gap: 3rem;
    transition: box-shadow 0.3s ease;
  }

  .trust-banner-blockchain:hover {
    box-shadow: 0 10px 40px rgba(0,0,0,0.6);
  }

  .blockchain-icon {
    flex: 0 0 70px;
    width: 70px;
    height: 70px;
    min-width: 70px;
    max-width: 70px;
    color: var(--color-brass);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto;
  }
  
  .blockchain-icon svg { 
    width: 100%; 
    height: auto;
    display: block;
  }

  .blockchain-content h3 {
    font-size: 1.8rem;
    color: var(--color-parchment);
    font-family: var(--font-heading);
    margin-bottom: 1rem;
  }

  .blockchain-content p {
    color: #D4D4D0;
    font-size: 1.05rem;
    line-height: 1.7;
    margin: 0;
  }

  .blockchain-content strong {
    color: var(--color-brass);
    font-weight: 600;
  }
  
  .blockchain-content em {
    color: var(--color-parchment);
  }

  @media (max-width: 900px) {
    .trust-grid {
      grid-template-columns: 1fr;
      gap: 4rem;
    }
  }

  @media (max-width: 768px) {
    .trust-banner-blockchain {
      flex-direction: column;
      text-align: center;
      gap: 1.5rem;
      padding: 2rem;
    }
  }
</style>
