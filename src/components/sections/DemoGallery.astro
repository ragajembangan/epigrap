---
import { getDemoGallery } from '../../lib/sanity';
import imageUrlBuilder from '@sanity/image-url';
import { sanityClient } from 'sanity:client';

const builder = imageUrlBuilder(sanityClient);
function urlFor(source: any) {
  return builder.image(source);
}

export interface DemoItem {
  title: string;
  description: string;
  image: string;
  url: string;
}

export interface DemoSector {
  sectorTitle: string;
  sectorIcon: string;
  items: DemoItem[];
}

// ─── Hardcoded fallback (digunakan jika CMS belum diisi) ───
const fallbackSectors: DemoSector[] = [
  {
    sectorTitle: "Pariwisata & Cagar Budaya",
    sectorIcon: "",
    items: [
      {
        title: "Wisata Candi & Sejarah",
        description: "Mockup portal digital Candi Dieng dengan audio multibahasa dan galeri interaktif.",
        image: "https://images.unsplash.com/photo-1588668214407-6ea9a6d8c272?q=80&w=400&auto=format&fit=crop",
        url: "/demo/wisata",
      },
      {
        title: "Wisata Religi & Ziarah Wali",
        description: "Digitalisasi makam tokoh agama untuk menampung peziarah dan jalur infaq digital.",
        image: "https://images.unsplash.com/photo-1466442929976-97f336a657be?q=80&w=400&auto=format&fit=crop",
        url: "/demo/religi",
      },
    ],
  },
  {
    sectorTitle: "Pemerintahan & Institusi",
    sectorIcon: "",
    items: [
      {
        title: "Prasasti Peresmian Pemerintah",
        description: "Prasasti digital untuk gedung negara, tugu peringatan, dan monumen peresmian.",
        image: "https://images.unsplash.com/photo-1577717903315-1691ae25ab3f?q=80&w=400&auto=format&fit=crop",
        url: "/demo/pemerintahan",
      },
      {
        title: "Yayasan & Pondok Pesantren",
        description: "Profil pesantren, arsip kitab kuning, dan jalur donasi atau wakaf digital.",
        image: "https://images.unsplash.com/photo-1590076215667-875c2d76b707?q=80&w=400&auto=format&fit=crop",
        url: "/demo/institusi",
      },
      {
        title: "Aset Perusahaan & Gedung",
        description: "Tonggak sejarah (milestone) perusahaan untuk lobi gedung, pabrik, atau kantor pusat.",
        image: "https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?q=80&w=400&auto=format&fit=crop",
        url: "/demo/korporasi",
      },
    ],
  },
  {
    sectorTitle: "Kreatif & Monumen Publik",
    sectorIcon: "",
    items: [
      {
        title: "Monumen Kesenian & Ruang Publik",
        description: "Patung & instalasi seni yang terhubung langsung ke profil paguyuban kreator.",
        image: "https://images.unsplash.com/photo-1561839561-b13bcfe95249?q=80&w=400&auto=format&fit=crop",
        url: "/demo/monumen",
      },
      {
        title: "Kreator, Penemu & Penulis",
        description: "Plakat QR untuk penghargaan karya, peluncuran buku, atau tautan penjualan langsung.",
        image: "https://images.unsplash.com/photo-1518998053901-5348d3961a04?q=80&w=400&auto=format&fit=crop",
        url: "/demo/kreator",
      },
    ],
  },
  {
    sectorTitle: "Privat & Keluarga",
    sectorIcon: "",
    items: [
      {
        title: "Silsilah Trah / Bani",
        description: "Portal memori keluarga besar, arsip foto leluhur, dan pesan suara lintas generasi.",
        image: "https://images.unsplash.com/photo-1529156069898-49953e39b3ac?q=80&w=400&auto=format&fit=crop",
        url: "/demo/keluarga",
      },
      {
        title: "Makam Pusaka & Bongpay",
        description: "Digitalisasi nisan dan bongpay Tionghoa untuk merawat sanad keluarga lintas abad.",
        image: "https://images.unsplash.com/photo-1554907984-15263bfd63bd?q=80&w=400&auto=format&fit=crop",
        url: "/demo/pusaka",
      },
    ],
  },
];

// ─── Fetch dari CMS, fallback ke hardcoded ───
const cmsData = await getDemoGallery();

// Header
const pageTitle = cmsData?.pageTitle || 'Galeri';
const pageTitleAccent = cmsData?.pageTitleAccent || 'Purwarupa';
const pageDescription = cmsData?.pageDescription || 'Jelajahi contoh portal digital interaktif dari berbagai sektor. Pindai, sentuh, dan rasakan pengalaman phygital sesungguhnya.';

// Sectors: transform CMS data ke format lokal, atau pakai fallback
let sectors: DemoSector[];

if (cmsData?.sectors && cmsData.sectors.length > 0) {
  sectors = cmsData.sectors.map((s) => ({
    sectorTitle: s.sectorTitle || '',
    sectorIcon: s.sectorIcon || '',
    items: (s.items || []).map((item) => ({
      title: item.itemTitle || '',
      description: item.itemDescription || '',
      image: item.itemImage
        ? urlFor(item.itemImage).width(400).height(533).quality(60).auto('format').url()
        : item.itemImageUrl || '',
      url: item.itemUrl || '#',
    })),
  }));
} else {
  sectors = fallbackSectors;
}
---

<section class="demo-gallery-section">
  <div class="container">
    <!-- Page Header -->
    <div class="demo-gallery-header">
      <h1 class="demo-gallery-title">
        {pageTitle} <span class="text-brass">{pageTitleAccent}</span>
      </h1>
      <p class="demo-gallery-desc">
        {pageDescription}
      </p>
    </div>

    <!-- Sectors -->
    {sectors.map((sector) => (
      <div class="demo-sector">
        <div class="sector-header">
          <span class="sector-icon">{sector.sectorIcon}</span>
          <h2 class="sector-title">{sector.sectorTitle}</h2>
          <div class="sector-line"></div>
        </div>

        <div class={`demo-grid demo-grid-${sector.items.length}`}>
          {sector.items.map((demo) => (
            <a
              href={demo.url}
              class="demo-card"
              aria-label={`Buka demo ${demo.title}`}
            >
              {/* Background Image */}
              <img
                src={demo.image}
                alt={demo.title}
                class="demo-card-img"
                loading="lazy"
                decoding="async"
                width="400"
                height="533"
                fetchpriority="low"
              />

              {/* Dark Overlay */}
              <div class="demo-card-overlay"></div>

              {/* Content */}
              <div class="demo-card-content">
                {/* Top: empty space for badge area */}
                <div class="demo-card-top"></div>

                {/* Bottom: Title + Description + Action */}
                <div class="demo-card-bottom">
                  <h3 class="demo-card-title">{demo.title}</h3>
                  <p class="demo-card-desc">{demo.description}</p>
                  <span class="demo-card-action">Buka Portal →</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  /* =============================================
     DEMO GALLERY — Section
     ============================================= */
  .demo-gallery-section {
    padding: 8rem 0 4rem;
    background-color: var(--color-obsidian);
    min-height: 100vh;
  }

  .demo-gallery-header {
    text-align: center;
    margin-bottom: 5rem;
  }

  .demo-gallery-title {
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: 1rem;
  }

  .demo-gallery-desc {
    color: #888;
    max-width: 600px;
    margin: 0 auto;
    font-size: 1.1rem;
    line-height: 1.7;
  }

  /* =============================================
     SECTOR GROUP
     ============================================= */
  .demo-sector {
    margin-bottom: 4rem;
  }

  .sector-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .sector-icon {
    font-size: 1.3rem;
    flex-shrink: 0;
  }

  .sector-title {
    font-family: var(--font-heading);
    font-size: clamp(1.1rem, 2.5vw, 1.5rem);
    color: var(--color-parchment);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .sector-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(
      to right,
      rgba(197, 160, 89, 0.4),
      transparent
    );
    margin-left: 0.5rem;
  }

  /* =============================================
     GRID LAYOUT
     Mobile: 2 cols | Tablet+: 3 cols
     Grid adjusts based on item count
     ============================================= */
  .demo-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }

  @media (min-width: 640px) {
    .demo-grid {
      gap: 16px;
    }
  }

  @media (min-width: 768px) {
    .demo-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
    }

    /* 2-item rows: slightly larger cards, max-width */
    .demo-grid-2 {
      grid-template-columns: repeat(2, 1fr);
      max-width: 800px;
    }
  }

  @media (min-width: 1200px) {
    .demo-grid {
      gap: 28px;
    }
  }

  /* =============================================
     CARD
     ============================================= */
  .demo-card {
    position: relative;
    display: flex;
    border-radius: 16px;
    overflow: hidden;
    aspect-ratio: 3 / 4;
    cursor: pointer;
    text-decoration: none;
    color: inherit;
    background-color: var(--color-granite);
  }

  /* ---- Image ---- */
  .demo-card-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    will-change: transform;
  }

  /* ---- Overlay ---- */
  .demo-card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(10, 10, 10, 0.1) 0%,
      rgba(10, 10, 10, 0.15) 35%,
      rgba(10, 10, 10, 0.88) 100%
    );
    transition: background 0.4s ease;
    z-index: 1;
  }

  /* ---- Content container ---- */
  .demo-card-content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    width: 100%;
    padding: 1rem;
  }

  /* ---- Title ---- */
  .demo-card-title {
    font-family: var(--font-heading);
    font-size: 0.85rem;
    font-weight: 700;
    color: #fff;
    line-height: 1.3;
    margin: 0 0 0.25rem;
  }

  /* ---- Description (hidden on mobile) ---- */
  .demo-card-desc {
    font-size: 0.7rem;
    color: #aaa;
    line-height: 1.5;
    margin: 0;
    display: none;
  }

  /* ---- Action text ---- */
  .demo-card-action {
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--color-brass);
    margin-top: 0.4rem;
    display: none; /* hidden on mobile */
  }

  /* =============================================
     TABLET (min-width: 640px)
     ============================================= */
  @media (min-width: 640px) {
    .demo-card-content {
      padding: 1.25rem;
    }

    .demo-card-title {
      font-size: 1rem;
    }

    .demo-card-desc {
      display: block;
      font-size: 0.75rem;
    }

    .demo-card-action {
      display: block;
      font-size: 0.75rem;
    }
  }

  /* =============================================
     DESKTOP (min-width: 768px)
     ============================================= */
  @media (min-width: 768px) {
    .demo-card-content {
      padding: 1.5rem;
    }

    .demo-card-title {
      font-size: 1.25rem;
      margin-bottom: 0.4rem;
    }

    .demo-card-desc {
      font-size: 0.8rem;
      line-height: 1.6;
    }

    .demo-card-action {
      font-size: 0.8rem;
      margin-top: 0.6rem;
      /* Desktop: hide by default, slide up on hover */
      opacity: 0;
      transform: translateY(8px);
      transition: all 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }

    /* ---- Hover effects (desktop only) ---- */
    .demo-card:hover .demo-card-img {
      transform: scale(1.08);
    }

    .demo-card:hover .demo-card-overlay {
      background: linear-gradient(
        180deg,
        rgba(10, 10, 10, 0.2) 0%,
        rgba(10, 10, 10, 0.3) 35%,
        rgba(10, 10, 10, 0.94) 100%
      );
    }

    .demo-card:hover .demo-card-action {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* =============================================
     DESKTOP XL (min-width: 1200px)
     ============================================= */
  @media (min-width: 1200px) {
    .demo-card-content {
      padding: 1.75rem;
    }

    .demo-card-title {
      font-size: 1.4rem;
    }

    .demo-card-desc {
      font-size: 0.85rem;
    }

    .demo-card-action {
      font-size: 0.85rem;
    }
  }
</style>
