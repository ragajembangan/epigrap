---

export interface Props {
  title: string;
  description: string;
  pubDate: Date;
  coverImage: any;
  url: string;
  tags?: string[];
  category?: string;
}

const { title, description, pubDate, coverImage, url, tags = [], category = '' } = Astro.props;

// Formatting date
const formattedDate = new Intl.DateTimeFormat("id-ID", {
  day: "numeric",
  month: "long",
  year: "numeric",
}).format(pubDate);
---

<a href={url} class="blog-card group" data-title={title.toLowerCase()} data-desc={description.toLowerCase()} data-tags={tags.join(',').toLowerCase()} data-category={category}>
  <div class="blog-card-img-wrapper">
    <img
      src={coverImage}
      alt={title}
      class="blog-card-img"
      loading="lazy"
    />
    <div class="blog-img-overlay"></div>
  </div>
  <div class="blog-card-content">
    <time datetime={pubDate.toISOString()} class="blog-card-date">
      {formattedDate}
    </time>
    <h3 class="blog-card-title">{title}</h3>
    {tags.length > 0 && (
      <div class="blog-card-tags">
        {tags.map(tag => <span class="blog-tag">{tag}</span>)}
      </div>
    )}
    <p class="blog-card-desc">{description}</p>
    <span class="blog-card-readmore">Baca Artikel →</span>
  </div>
</a>

<style>
  .blog-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    background-color: var(--color-granite);
    border-radius: 12px;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    border: 1px solid rgba(197, 160, 89, 0.1);
  }

  .blog-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4);
    border-color: rgba(197, 160, 89, 0.3);
  }

  .blog-card-img-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }

  .blog-card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .blog-card:hover .blog-card-img {
    transform: scale(1.05);
  }

  .blog-img-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      transparent 50%,
      rgba(10, 10, 10, 0.8) 100%
    );
    z-index: 1;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .blog-card-content {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .blog-card-date {
    font-size: 0.8rem;
    color: var(--color-brass);
    margin-bottom: 0.5rem;
    font-weight: 500;
  }

  .blog-card-title {
    font-family: var(--font-heading);
    font-size: 1.3rem;
    color: var(--color-parchment);
    line-height: 1.4;
    margin-bottom: 1rem;
    transition: color 0.3s ease;
  }

  .blog-card:hover .blog-card-title {
    color: var(--color-brass);
  }

  .blog-card-desc {
    font-size: 0.9rem;
    color: #a0a0a0;
    line-height: 1.6;
    margin-bottom: 1.5rem;
    flex-grow: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .blog-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 0.8rem;
  }

  .blog-tag {
    display: inline-flex;
    align-items: center;
    font-size: 0.7rem;
    padding: 0.2rem 0.6rem;
    border-radius: 50px;
    background: rgba(197, 160, 89, 0.12);
    color: var(--color-brass);
    font-weight: 500;
    letter-spacing: 0.5px;
    white-space: nowrap;
  }

  .blog-card-readmore {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-parchment);
    text-transform: uppercase;
    letter-spacing: 1px;
    align-self: flex-start;
    transition: color 0.3s ease;
    border-bottom: 1px solid transparent;
  }

  .blog-card:hover .blog-card-readmore {
    color: var(--color-brass);
    border-color: var(--color-brass);
  }
</style>
