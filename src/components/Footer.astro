        </div>
        <a href="mailto:support@epigrap.com" class="brand-email">support@epigrap.com</a>
      </div>

      <!-- Jelajahi -->
      <div class="footer-links">
        <h3>Jelajahi</h3>
        <ul>
          <li><a href="/home">Beranda</a></li>
          <li><a href="/demo">Portal Demo</a></li>
          <li><a href="/price">Harga</a></li>
          <li><a href="/partner">Partnership</a></li>
          <li><a href="/blog">Blog & Insights</a></li>
        </ul>
      </div>

      <!-- Perusahaan -->
      <div class="footer-links">
        <h3>Perusahaan</h3>
        <ul>
          <li><a href="/about">Tentang Epigrap</a></li>
          <li><a href="/dasbor">Dasbor Klien</a></li>
        </ul>
      </div>

      <!-- Legal -->
      <div class="footer-links">
        <h3>Legal</h3>
        <ul>
          <li><a href="/privasi">Kebijakan Privasi</a></li>
          <li><a href="/syarat-ketentuan">Syarat & Ketentuan</a></li>
          <li><a href="/kebijakan-pengembalian-dana">Pengembalian Dana</a></li>
          <li><a href="/pelepasan-tanggung-jawab">Pelepasan Tanggung Jawab</a></li>
        </ul>
      </div>

    </div>

    <!-- Footer Bottom -->
    <div class="footer-bottom">
      <a href="/" class="footer-glow-link">
        <span>© {currentYear} Epigrap &middot; Indonesia</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
