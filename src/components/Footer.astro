        </svg>
      </a>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: #050505;
    padding: 6rem 0 2rem;
    border-top: 1px solid rgba(197, 160, 89, 0.2);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2.5fr 1fr 1fr 1fr;
    gap: 3rem;
    margin-bottom: 4rem;
  }

  /* Brand */
  .logo {
    font-family: var(--font-heading);
    color: var(--color-brass);
    font-size: 1.8rem;
    letter-spacing: 3px;
    margin-bottom: 1rem;
  }

  .tagline {
    font-family: var(--font-heading);
    font-size: 1rem;
    color: var(--color-parchment);
    line-height: 1.6;
    margin-bottom: 0.75rem;
  }

  .description {
    color: #777;
    font-size: 0.85rem;
    line-height: 1.7;
    max-width: 400px;
    margin-bottom: 1.5rem;
  }

  /* Social Icons */
  .social-icons {
    display: flex;
    gap: 0.75rem;
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.1);
    background: rgba(255,255,255,0.04);
    color: #888;
    transition: all 0.3s ease;
    text-decoration: none;
  }

  .social-link:hover {
    color: var(--color-brass);
    border-color: rgba(197,160,89,0.5);
    background: rgba(197,160,89,0.08);
    transform: translateY(-2px);
  }

  .brand-email {
    display: inline-block;
    margin-top: 1.5rem;
    color: rgba(197,160,89,0.8);
    font-size: 0.9rem;
    text-decoration: none;
    transition: color 0.2s;
  }

  .brand-email:hover {
    color: var(--color-brass);
  }

  /* Nav Columns */
  .footer-links h3 {
    font-family: var(--font-heading);
    color: var(--color-parchment);
    font-size: 1rem;
    margin-bottom: 1.25rem;
    font-weight: 600;
    letter-spacing: 0.5px;
  }

  .footer-links ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-links li {
    margin-bottom: 0.7rem;
  }

  .footer-links a {
    color: #777;
    font-size: 0.875rem;
    transition: color 0.2s;
    text-decoration: none;
  }

  .footer-links a:hover {
    color: var(--color-brass);
  }

  /* Bantuan / Contact */
  .contact-label {
    color: #666;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 0.4rem;
  }

  .contact-email {
    color: var(--color-brass);
    font-size: 0.9rem;
    font-weight: 500;
    text-decoration: underline;
    text-underline-offset: 4px;
    transition: opacity 0.2s;
  }

  .contact-email:hover {
    opacity: 0.75;
  }

  /* Footer Bottom */
  .footer-bottom {
    border-top: 1px solid rgba(255,255,255,0.07);
    padding-top: 1.75rem;
    text-align: center;
    color: #555;
    font-size: 0.82rem;
  }

  .footer-glow-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-brass);
    font-family: var(--font-body);
    font-size: 0.85rem;
    letter-spacing: 0.05em;
    text-decoration: none;
    animation: glow-pulse-footer 4s ease-in-out infinite;
  }

  .footer-glow-link:hover {
    opacity: 1;
    color: #F0D080;
    animation: none;
    text-shadow: 0 0 10px #C5A059, 0 0 25px rgba(197,160,89,0.5), 0 0 40px rgba(197,160,89,0.2);
  }

  .footer-glow-link svg {
    color: var(--color-brass);
  }

  @keyframes glow-pulse-footer {
    0%, 100% {
      opacity: 0.3;
      text-shadow: none;
      filter: none;
    }
    50% {
      opacity: 0.85;
      color: #F0D080;
      text-shadow: 0 0 6px #C5A059, 0 0 18px rgba(197,160,89,0.35);
      filter: drop-shadow(0 0 5px rgba(197,160,89,0.25));
    }
  }

  /* Responsive */
  @media (max-width: 1100px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr 1fr;
      gap: 2.5rem;
    }
    .footer-brand {
      grid-column: 1 / -1;
    }
    .description { max-width: 100%; }
  }

  @media (max-width: 640px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }
    .footer-brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 400px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
